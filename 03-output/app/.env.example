# ====================================================================
# Tester Match — 환경 변수 템플릿
# .env.local 로 복사 후 실제 값을 채워 사용. .env.local 은 git 추적 X.
# ====================================================================

# ── Supabase ────────────────────────────────────────────────────────
# 신 키 규격(2025+): publishable(클라이언트) / secret(서버). 구 anon/service_role 도 호환.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# ── Resend (메인 메일) ──────────────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@YOUR_DOMAIN

# ── Brevo (백업 메일, 100/일 초과 시 fallback) ──────────────────────
BREVO_API_KEY=xkeysib-xxx
BREVO_FROM_EMAIL=hello@YOUR_DOMAIN

# ── 토스페이먼츠 (v1 결제) ───────────────────────────────────────────
TOSS_CLIENT_KEY=test_ck_xxx
TOSS_SECRET_KEY=test_sk_xxx
TOSS_WEBHOOK_SECRET=

# ── NextAuth (Auth.js v5) ───────────────────────────────────────────
AUTH_SECRET=
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# ── Sentry / PostHog (관찰성) ────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=

# ── 앱 설정 ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Tester Match
